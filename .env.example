# Supabase — get from supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Microsoft Azure AD — get from portal.azure.com > App Registrations
VITE_AZURE_CLIENT_ID=your-client-id
VITE_AZURE_TENANT_ID=your-tenant-id

# Google Maps — get from console.cloud.google.com (enable Maps JS API + Visualization)
VITE_GOOGLE_MAPS_KEY=your-google-maps-key
